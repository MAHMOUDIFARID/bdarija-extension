{
  "extends": "./.wxt/types/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2022"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "paths": {
      "~/*": ["./*"]
    }
  },
  "include": [
    "**/*",
    ".wxt/types"
  ]
}
