# Server port (defaults to 8787)
PORT=8787

# Optional backend fallback keys. User-provided extension keys are sent per request
# and are never stored by the backend.
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
AI_API_KEY=

# Optional backend fallback defaults
AI_PROVIDER=gemini
AI_STYLE=casual
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_MODEL=gpt-5.5
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b

# Optional Agent Router compatible fallback
AGENT_ROUTER_API_KEY=
AGENT_ROUTER_TOKEN=
AGENT_ROUTER_BASE_URL=https://agentrouter.org/v1
AGENT_ROUTER_MODEL=gpt-5
OPENAI_BASE_URL=https://api.openai.com/v1
